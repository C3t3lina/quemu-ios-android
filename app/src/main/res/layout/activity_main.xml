<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1a1a1a"
        android:elevation="4dp"/>

    <!-- Status bar -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="Iniciando..."
        android:textColor="#ffffff"
        android:textSize="13sp"
        android:background="#111111"
        android:fontFamily="monospace"/>

    <!-- VM Display (ocupa todo el espacio disponible) -->
    <com.iosvm.android.ui.VMScreen
        android:id="@+id/vm_screen"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"/>

    <!-- Control bar (visible solo cuando la VM está corriendo) -->
    <LinearLayout
        android:id="@+id/control_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#1a1a1a"
        android:visibility="gone"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btn_keyboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#ffffff"
            android:contentDescription="Teclado"/>

        <ImageButton
            android:id="@+id/btn_snapshot"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:src="@android:drawable/ic_menu_save"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#ffffff"
            android:contentDescription="Snapshot"/>

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="4dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#ffffff"
            android:contentDescription="Ajustes"/>

    </LinearLayout>

    <!-- Bottom buttons (solo cuando la VM está parada) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1a1a1a"
        android:padding="8dp">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="▶ Iniciar VM"
            android:backgroundTint="#007aff"
            android:textColor="#ffffff"/>

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="⏹ Detener"
            android:backgroundTint="#ff3b30"
            android:textColor="#ffffff"/>

    </LinearLayout>

</LinearLayout>
